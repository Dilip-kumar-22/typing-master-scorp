# ───────── Dependencies ─────────
node_modules/
app/node_modules/

# ───────── Build output ─────────
dist/
app/dist/
*.tsbuildinfo

# ───────── Vite / tooling caches ─────────
app/.vite/
.vite/
.eslintcache

# ───────── Secrets — NEVER commit ─────────
.env
.env.local
.env.*.local
app/.env
app/.env.local
app/.env.*.local
# (app/.env.example IS committed — it is the template with empty values)

# ───────── Native signing — NEVER commit ─────────
app/android/app/release-key.keystore
app/android/keystore.properties
app/ios/App/*.mobileprovision
app/ios/App/*.p12

# ───────── Capacitor native — projects ARE committed (per project decision),
#           but their generated BUILD artifacts are not ─────────
app/android/.gradle/
app/android/build/
app/android/app/build/
app/android/local.properties
app/android/captures/
app/android/.idea/
app/ios/App/build/
app/ios/App/Pods/
app/ios/DerivedData/
app/ios/App/output/

# ───────── Logs ─────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────── Editor / OS junk ─────────
.vscode/
.idea/
# local Claude Code tooling (launch.json etc.) — machine-specific
.claude/
*.swp
.DS_Store
Thumbs.db
