# Copy this file to `.env.local` and fill in your Supabase project credentials.
# Without these, the app runs in LOCAL-ONLY mode (localStorage persistence,
# no auth, no cloud sync, no leaderboard) — useful for offline development.
#
# 5-minute setup:
#   1. Create a free project at https://supabase.com
#   2. Project settings → API → copy the URL and the anon (public) key
#   3. Paste them here
#   4. SQL Editor → paste supabase/migrations/0001_init.sql → Run
#
# Vite exposes only env vars prefixed with VITE_ to the client bundle,
# so these CANNOT leak server-side secrets — only the anon key, which is
# designed to be public (the database is protected by Row-Level Security).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — PostHog analytics. Without this, analytics is silently disabled.
# Get a key at https://posthog.com → Project Settings → Project API Key.
# VITE_POSTHOG_HOST defaults to https://us.i.posthog.com; set it to
# https://eu.i.posthog.com if your project is in the EU region.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Optional — Stripe (Phase 9 monetization). Without this, billing UI is
# silently hidden and every user stays on the Free tier forever.
# Get the publishable key at https://dashboard.stripe.com → Developers → API keys.
# (Server-side secrets — STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# STRIPE_PRO_PRICE_ID, STRIPE_TEAM_PRICE_ID — are set on the Supabase
# edge functions via `supabase secrets set`. See STRIPE_SETUP.md.)
VITE_STRIPE_PUBLISHABLE_KEY=
